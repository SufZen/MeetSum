# Meeting Intelligence — Environment Variables
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
MEETINGS_APP_URL=http://127.0.0.1:3000
APP_PORT=3000

# Core self-hosted services
DATABASE_URL=postgres://meetings:meetings@postgres:5432/meetings
MEETSUM_STORAGE=postgres
MEETSUM_REQUIRE_API_KEY=true
MEETSUM_API_KEYS=replace-with-long-random-dev-key
MEETSUM_API_KEY=replace-with-long-random-dev-key
MEETSUM_API_KEY_HASHES=
REDIS_URL=redis://redis:6379
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=meetings
S3_SECRET_KEY=meetings-secret
S3_BUCKET=meeting-media

# Google Workspace domain-wide delegation
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@example.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_PUBSUB_PROJECT_ID=
GOOGLE_GMAIL_TOPIC=

# AI providers. Keep local providers as default; use API fallback for hard Hebrew.
LOCAL_TRANSCRIPTION_URL=http://localhost:8000
OPENAI_API_KEY=
AI_GATEWAY_API_KEY=
GOOGLE_GEMINI_API_KEY=
LOCAL_GEMMA_URL=http://localhost:11434

# Automation and business systems
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=
REALIZEOS_API_URL=
REALIZEOS_API_KEY=
WEBHOOK_SIGNING_SECRET=dev-secret
