# Meeting Intelligence — Environment Variables
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
MEETINGS_APP_URL=http://127.0.0.1:3000
APP_PORT=3000

# Core self-hosted services
DATABASE_URL=postgres://meetings:meetings@meetsum-postgres:5432/meetings
MEETSUM_STORAGE=postgres
MEETSUM_REQUIRE_API_KEY=true
MEETSUM_API_KEYS=replace-with-long-random-dev-key
MEETSUM_API_KEY=replace-with-long-random-dev-key
MEETSUM_API_KEY_HASHES=
MEETSUM_SESSION_SECRET=replace-with-long-random-session-secret
MEETSUM_ALLOWED_EMAILS=info@realization.co.il
REDIS_URL=redis://meetsum-redis:6379
S3_ENDPOINT=http://meetsum-minio:9000
S3_ACCESS_KEY=meetings
S3_SECRET_KEY=meetings-secret
S3_BUCKET=meeting-media

# Google Workspace domain-wide delegation
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@example.com
GOOGLE_WORKSPACE_SUBJECT=info@realization.co.il
GOOGLE_SERVICE_ACCOUNT_EMAIL=meetsum-workspace-sync@meetsum-494211.iam.gserviceaccount.com
# Production uses keyless IAM Credentials signJwt. Leave private key/key file empty unless developing locally.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=
GOOGLE_PUBSUB_PROJECT_ID=
GOOGLE_GMAIL_TOPIC=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://meetsum.realization.co.il/api/auth/google/callback

# AI providers. Keep local providers as default; use API fallback for hard Hebrew.
LOCAL_TRANSCRIPTION_URL=http://localhost:8000
OPENAI_API_KEY=
AI_GATEWAY_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=meetsum-494211
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/opt/meetsum/secrets/vertex-ai-runtime.json
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_AUDIO_MODEL=gemini-2.5-flash
GOOGLE_GEMINI_SUMMARY_MODEL=gemini-2.5-flash
GOOGLE_GEMINI_INLINE_AUDIO_LIMIT_BYTES=18000000
LOCAL_GEMMA_URL=http://localhost:11434

# Automation and business systems
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=
# On the VPS, RealizeOS currently runs on the host at port 8082.
REALIZEOS_API_URL=http://host.docker.internal:8082
REALIZEOS_API_KEY=
WEBHOOK_SIGNING_SECRET=dev-secret
MEETSUM_SCHEDULE_GOOGLE_SYNC=true
MEETSUM_SCHEDULE_CALENDAR_SYNC=true
# Keep Drive manual until storage retention and import selection are tuned.
MEETSUM_SCHEDULE_DRIVE_SYNC=false
MEETSUM_CALENDAR_POLL_MINUTES=15
MEETSUM_CALENDAR_LOOKBACK_DAYS=30
MEETSUM_CALENDAR_LOOKAHEAD_DAYS=60
MEETSUM_CALENDAR_IMPORT_ALL=false
MEETSUM_CALENDAR_EXCLUDED_CALENDAR_PATTERNS=holiday,birthday,reminder,task
MEETSUM_CALENDAR_EXCLUDED_TITLE_PATTERNS=break,brunch,dinner,gym,lunch,me time,sleep,workout
MEETSUM_DRIVE_POLL_MINUTES=30
MEETSUM_DRIVE_MAX_IMPORTS_PER_POLL=2
MEETSUM_DRIVE_MAX_IMPORT_BYTES=2000000000
REALIZEOS_MEETING_CONTEXT_PATH=/api/meeting-context
